class String {
    Vec<u8> chars;

    String() {
        self.chars = Vec::new();
    }

    String(unt init_capacity) {
        self.chars = Vec::with_capacity(init_capacity);
    }

    fun to_str(): str {

    }
}

module String {
    fun new(): String {
        return String();
    }

    fun with_capacity(unt init_capacity): String {
        return String(init_capacity);
    }
}