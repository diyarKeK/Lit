import str::String;

interface Formatter {
    fun fmt(): str;
}

impl Formatter {

// TODO - implement method fmt() for types: unt, int and float

    $unt {
        override fun fmt(): str {
            return "";
        }
    }

    $int {
        override fun fmt(): str {
            return "";
        }
    }

    $float {
        override fun fmt(): str {
            return "";
        }
    }

    $bool {
        override fun fmt(): str {
            return switch self {
                true => "true",
                false => "false",
            };
        }
    }

    $str {
        override fun fmt(): str {
            return self;
        }
    }
}