interface Formatter {
    fun fmt(): str;
}

$unt : Formatter {
    override fun fmt(): str {

    }
}

$int : Formatter {
    override fun fmt(): str {

    }
}

$float : Formatter {
    override fun fmt(): str {

    }
}

$bool : Formatter {
    override fun fmt(): str {
        return switch self {
            true => "true",
            false => "false",
        };
    }
}

$str : Formatter {
    override fun fmt(): str {
        return self;
    }
}